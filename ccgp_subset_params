# Population Parameters (To ideally be used across all analyses)

# General Params (be used across all pipelines)
#==================================
source params_base.sh
POPNAME=ccgp_subset
NUMIND=8
THREADS=30 # Likely should be adjusted for some analyses
REC_MAP=${OUTDIR}/datafiles/linkage_map/${POPNAME}_all.rmap


# B_Phylogenetics
#==================================

# MSMC input generation
k=150
prefix=GCF_041296385.1
METHOD=samtools  # or another variant calling method
INDFILE=${OUTDIR}/referencelists/ccgp_subset_IND.txt
# MSMC Analysis
POP_OR_IND=$POPNAME # Defaulting to file-wide population name here
DATE=`date +%m%d%y`
RUN_NAME=msmc_${POP_OR_IND}_${DATE}
P_PAR=1*2+1*3+8*1+1*2+1*2
sex_chr=LG9
nchr=`wc -l ${OUTDIR}/referencelists/SCAFFOLDS.txt | cut -f1 -d' '`
