INDEX=0,1,2,3,6,7,8,9,10,11,16,17

# GONE Input Generation
VCFFILE=${OUTDIR}/datafiles/rephased_vcf/placeholder.vcf.gz
SCAFFOLD_LIST=${OUTDIR}/referencelists/SCAFFOLDS_subset.txt # Will likely need to subset the scaffold list since GONE only accept larger chromosomes
MAX_MISSING=1
MAF=0.01
# GONE Analysis
INDIR=${OUTDIR}/datafiles/gone2_inputs/${POPNAME}
RECOMB_RATE="NONE" # Set to NONE to use a fine-scale recombination map
GENO_DTYPE=3
EXTRA_FLAGS= #Leave empty if none needed

# C_SelectionAnalysis
#==================================

# Flexsweep Analysis
NUM_HAPS=$(echo "$NUM_IND * 2" | bc) # Number of haploids.
NUM_SIMULATIONS=10000 # Default 10000
DEMES=${OUTDIR}/datafiles/demography/${POPNAME}.yaml